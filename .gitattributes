# This application is deployed and run on Linux (Raspberry Pi). Force LF line
# endings everywhere so shell scripts and Python never get CRLF on checkout,
# regardless of the contributor's OS or local core.autocrlf setting.
# (CRLF in a *.sh shebang line breaks the Linux interpreter: "bad interpreter".)
* text=auto eol=lf

# Be explicit for the file types that matter most on the target.
*.sh      text eol=lf
*.py      text eol=lf
*.html    text eol=lf
*.css     text eol=lf
*.js      text eol=lf
*.txt     text eol=lf
*.service text eol=lf
*.conf    text eol=lf

# Binary types: never apply line-ending normalization (would corrupt them).
*.db      binary
*.sqlite  binary
*.sqlite3 binary
*.png     binary
*.jpg     binary
*.jpeg    binary
*.gif     binary
*.ico     binary
*.woff    binary
*.woff2   binary
*.ttf     binary
*.eot     binary
*.pdf     binary
